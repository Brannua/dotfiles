alias q=exit
alias c=clear
alias l="ls -alh"

alias f=fish
alias s=fastfetch
alias fy=trans
alias down=yt-dlp

# proxy
alias proxy-on="export http_proxy='http://127.0.0.1:1080'; export all_proxy='socks5://127.0.0.1:8080'"
alias proxy-off="unset http_proxy; unset all_proxy"

# scripts
alias screen-saver-on="~/Documents/dotfiles/unstable/scripts/screen_control.sh on"
alias screen-saver-off="~/Documents/dotfiles/unstable/scripts/screen_control.sh off"

